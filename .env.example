# Базовый URL API ScanUp, без завершающего слэша
SCANUP_API_URL=http://localhost:3001

# Токен ноды — выдаётся один раз при создании ноды (POST /nodes или
# POST /nodes/admin). Хранить только в env, никогда не коммитить.
SCANUP_NODE_TOKEN=

# Необязательные настройки
# NODE_LOCATION=eu-central
# HEARTBEAT_INTERVAL_MS=30000
# POLL_INTERVAL_MS=3000
# ERROR_BACKOFF_MS=10000
